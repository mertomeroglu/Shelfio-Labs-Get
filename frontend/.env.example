# getshelfio.com Frontend Ortam Değişkenleri Şablonu

# Hizmet sitesinin yayınlandığı veya çalıştırıldığı URL
NEXT_PUBLIC_SITE_URL=https://getshelfio.com

# Shelfio platform ana şirketi (Labs) web sitesi
NEXT_PUBLIC_COMPANY_SITE_URL=https://shelfiolabs.com

# Müşteri destek ve iletişim e-postası
NEXT_PUBLIC_SUPPORT_EMAIL=info@getshelfio.com

# Backend API endpoint adresi (İnternet üzerinden erişilebilir URL)
NEXT_PUBLIC_API_BASE_URL=https://api.getshelfio.com/api

# Sunucu taraflı çağrılar (SSR) için dahili API adresi
API_INTERNAL_BASE_URL=http://localhost:4017/api

# Müşterilerin yönlendirileceği ana Shelfio panel giriş/arayüz adresi
NEXT_PUBLIC_SHELFIO_APP_URL=https://shelfiolabs.com/giris
