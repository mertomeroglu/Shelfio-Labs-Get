APP_NAME=Shelfio
NODE_ENV=development
PORT=4017

FRONTEND_ORIGIN=http://localhost:3007
PUBLIC_SITE_URL=https://getshelfio.com
MAIN_APP_URL=https://shelfiolabs.com/
CORS_ORIGIN=http://localhost:3007,https://getshelfio.com,https://www.getshelfio.com

DATABASE_URL=
DATABASE_SSL=false

SESSION_SECRET=
SESSION_TTL_SECONDS=86400
LICENSE_KEY_PEPPER=
CONTROL_API_INTERNAL_SECRET=
SSO_CODE_TTL_SECONDS=120

COOKIE_NAME=shelfio_service_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Shelfio <info@getshelfio.com>"
SUPPORT_INBOX=info@shelfiolabs.com
DEMO_REQUEST_TO=info@shelfiolabs.com
DEMO_REQUEST_CC=
PASSWORD_RESET_FROM="Shelfio <info@getshelfio.com>"

EMAIL_SEND_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

PAYMENT_TEST_MODE=true
CHECKOUT_ENABLED=true

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin_password
SEED_CUSTOMER_EMAIL=customer@example.com
SEED_CUSTOMER_PASSWORD=customer_password
SEED_CUSTOMER_LICENSE_KEY=SHELFIO-MAIN-EXAMPLE-KEY
